<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC"
    android:orientation="vertical"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBookingServiceBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="Назад"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_previous"
        android:tint="#6A4435" />

    <TextView
        android:id="@+id/tvBookingServiceTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Выберите услугу"
        android:textColor="#2E1A12"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvBookingServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#A33A2D"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvBookingServiceEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="У мастера пока нет услуг"
        android:textColor="#7A5B4D"
        android:textSize="16sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBookingServices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="10dp" />

    <Button
        android:id="@+id/btnContinueBookingService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#D27D56"
        android:text="Далее"
        android:textColor="#FFFFFF" />
</LinearLayout>
