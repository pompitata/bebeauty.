<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F1EC">

    <LinearLayout
        android:id="@+id/layoutMasterHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvHomeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Мои работы"
            android:textColor="#2E1A12"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHomeSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Добавляйте фотографии своих работ. Нажмите на фото, чтобы удалить его."
            android:textColor="#7A5B4D"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnAddWork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="#D27D56"
            android:paddingVertical="14dp"
            android:text="Добавить работу"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvWorksStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="#A33A2D"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvWorksEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="Пока нет добавленных работ"
            android:textColor="#7A5B4D"
            android:textSize="16sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWorks"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="18dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutClientHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Главная"
            android:textColor="#2E1A12"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilClientSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundColor="#FFF7F2"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="20dp"
                app:boxCornerRadiusBottomStart="20dp"
                app:boxCornerRadiusTopEnd="20dp"
                app:boxCornerRadiusTopStart="20dp"
                app:boxStrokeWidth="0dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etClientSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Поиск мастера по логину"
                    android:imeOptions="actionSearch"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="#2E1A12"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnClientCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:backgroundTint="#E7D2C8"
                android:text="Отмена"
                android:textColor="#6A4435"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/btnClientBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#E7D2C8"
            android:text="Назад"
            android:textColor="#6A4435"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvClientStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#A33A2D"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvClientHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Выберите категорию или найдите мастера по логину."
            android:textColor="#7A5B4D"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClientCategories"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClientMasters"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvClientEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Мастера не найдены"
            android:textColor="#7A5B4D"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
