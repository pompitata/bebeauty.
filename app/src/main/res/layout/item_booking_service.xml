<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardBookingService"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFDFC"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#E7D2C8"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvBookingServiceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#2E1A12"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBookingServiceDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#7A5B4D"
            android:textSize="14sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
