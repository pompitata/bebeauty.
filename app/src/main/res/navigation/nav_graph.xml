<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="com.example.beautyapp.AuthFragment"
        android:label="Auth">
        <action
            android:id="@+id/action_auth_to_home"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_auth_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_auth_to_resetPassword"
            app:destination="@id/resetPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.beautyapp.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/resetPasswordFragment"
        android:name="com.example.beautyapp.ResetPasswordFragment"
        android:label="ResetPassword" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.beautyapp.HomeFragment">
        <action
            android:id="@+id/action_home_to_masterCard"
            app:destination="@id/masterCardFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingsFragment"
        android:name="com.example.beautyapp.BookingsFragment" />

    <fragment
        android:id="@+id/servicesFragment"
        android:name="com.example.beautyapp.ServicesFragment" />

    <fragment
        android:id="@+id/scheduleFragment"
        android:name="com.example.beautyapp.ScheduleFragment" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.beautyapp.ProfileFragment" />

    <fragment
        android:id="@+id/masterCardFragment"
        android:name="com.example.beautyapp.MasterCardFragment">
        <action
            android:id="@+id/action_masterCard_to_bookingService"
            app:destination="@id/bookingServiceFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingServiceFragment"
        android:name="com.example.beautyapp.BookingServiceFragment">
        <action
            android:id="@+id/action_bookingService_to_bookingSlots"
            app:destination="@id/bookingSlotsFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingSlotsFragment"
        android:name="com.example.beautyapp.BookingSlotsFragment" />

</navigation>
